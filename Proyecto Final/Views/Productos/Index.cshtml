        <span class="cerrar" id="cerrarModal">&times;</span>

        <div class="modal-layout">
            <div class="modal-izquierda">
                <img id="modalImagen" class="modal-img" src="" alt="Producto">

                <div class="info-extra">
                    <h3>Informacion adicional</h3>
                    <ul id="modalInfoExtra">
                        <li>Ingredientes de alta calidad.</li>
                        <li>Hecho con amor.</li>
                        <li>Entregas a domicilio.</li>
                    </ul>
                </div>
            </div>

            <div class="modal-derecha">
                <h2 id="modalTitulo"></h2>

                <div class="titulo-seccion">Descripcion</div>
                <div id="modalDescripcion" class="texto-descripcion"></div>

                <div class="titulo-seccion" id="tituloPrecio">Precio</div>
                <div id="modalPrecio" class="precio-box"></div>

                <div class="btn-whatsapp-box">
                    <a id="btnWhatsApp" class="btn-whatsapp" href="#" target="_blank">
                        <img class="icono-whatsapp" src="https://cdn-icons-png.flaticon.com/512/733/733585.png" alt="WhatsApp">
                        <span>Solicitar</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const categorias = document.querySelectorAll("#menuCategorias li");
    const productos = document.querySelectorAll(".producto");
    const tituloCategoria = document.getElementById("tituloCategoria");

    const params = new URLSearchParams(window.location.search);
    const categoriaUrl = params.get("categoria");

    if (categoriaUrl) {
        categorias.forEach(c => c.classList.remove("activo"));

        categorias.forEach(c => {
            if (c.getAttribute("data-categoria") === categoriaUrl) {
                c.classList.add("activo");
            }
        });

        tituloCategoria.textContent = categoriaUrl;

        productos.forEach(p => {
            if (p.getAttribute("data-categoria") === categoriaUrl) {
                p.style.display = "block";
            } else {
                p.style.display = "none";
            }
        });
    }

    categorias.forEach(item => {
        item.addEventListener("click", function () {
            const categoria = this.getAttribute("data-categoria");

            categorias.forEach(c => c.classList.remove("activo"));
            this.classList.add("activo");

            tituloCategoria.textContent = categoria;

            productos.forEach(p => {
                if (p.getAttribute("data-categoria") === categoria) {
                    p.style.display = "block";
                } else {
                    p.style.display = "none";
                }
            });
        });
    });

    const botonesDetalles = document.querySelectorAll(".btn-detalles");
    const modal = document.getElementById("modalDetalle");
    const cerrarModal = document.getElementById("cerrarModal");

    const modalImagen = document.getElementById("modalImagen");
    const modalTitulo = document.getElementById("modalTitulo");
    const modalDescripcion = document.getElementById("modalDescripcion");
    const modalPrecio = document.getElementById("modalPrecio");
    const btnWhatsApp = document.getElementById("btnWhatsApp");
    const tituloPrecio = document.getElementById("tituloPrecio");

    botonesDetalles.forEach(boton => {
        boton.addEventListener("click", function () {
            const imagen = this.getAttribute("data-imagen");
            const titulo = this.getAttribute("data-titulo");
            const descripcion = this.getAttribute("data-descripcion");
            const precio = this.getAttribute("data-precio");
            const mostrarPrecio = this.getAttribute("data-mostrarprecio");

            modalImagen.src = imagen;
            modalTitulo.innerHTML = titulo;
            modalDescripcion.innerHTML = descripcion;

            if (mostrarPrecio === "true") {
                tituloPrecio.style.display = "block";
                modalPrecio.style.display = "block";
                modalPrecio.innerHTML = precio;
            } else {
                if (precio && precio.trim() !== "") {
                    tituloPrecio.style.display = "block";
                    modalPrecio.style.display = "block";
                    modalPrecio.innerHTML = precio;
                } else {
                    tituloPrecio.style.display = "none";
                    modalPrecio.style.display = "none";
                }
            }

            const numero = "528997543659";
            const mensaje = "Hola, me interesa el producto: " + titulo;
            btnWhatsApp.href = `https://wa.me/${numero}?text=${encodeURIComponent(mensaje)}`;

            modal.style.display = "block";
            document.body.classList.add("modal-abierto");
        });
    });

    cerrarModal.addEventListener("click", function () {
        modal.style.display = "none";
        document.body.classList.remove("modal-abierto");
    });

    window.addEventListener("click", function (e) {
        if (e.target === modal) {
            modal.style.display = "none";
            document.body.classList.remove("modal-abierto");
        }
    });
</script>
