@{
    ViewData["Title"] = "Sobre Nosotros";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

<div class="hero-bg hero-kca">
    <div class="hero-content" style="position: relative; z-index: 2;">
        <h1>KCAMUEBLES</h1>
        <div class="decor-line"><i class="bi bi-diamond-fill"></i></div>
        <p class="hero-text">Tu espacio, tu estilo.</p>
    </div>
</div>

<div class="container mt-5">
    <div class="row g-4">
        <div class="col-md-6"><div class="card-about"><div class="icon-circle"><i class="bi bi-bullseye"></i></div><h3 class="titulo-linea">Misión</h3><p style="font-family:'Montserrat', sans-serif">Brindar soluciones funcionales, modernas y accesibles a través de muebles modulares inspirados en el diseño escandinavo y minimalista, con materiales resistentes y diseños que se adapten a cada hogar u oficina.</p></div></div>
        <div class="col-md-6"><div class="card-about"><div class="icon-circle"><i class="bi bi-stars"></i></div><h3 class="titulo-linea">Visión</h3><p style="font-family:'Montserrat', sans-serif">Ser una empresa reconocida regional y nacionalmente por la calidad, innovación y diseño de nuestros muebles modulares, creando ambientes únicos con comodidad, estilo y personalidad.</p></div></div>
    </div>

    <div class="historia-box">
        <div class="row align-items-center">
            <div class="col-md-4 text-center"><div class="historia-img-wrapper"><img src="/imagenes/logomadera.jpeg" class="historia-img" alt="KCAMUEBLES sobre madera"></div></div>
            <div class="col-md-8">
                <div class="historia-header"><div class="icon-circle"><i class="bi bi-house-heart"></i></div><h3 class="titulo-linea">Historia de la empresa</h3></div>
                <p style="font-family:'Montserrat', sans-serif">El <b style="color:#8B0909; font-weight:bold">12 de marzo de 2024</b> nació KCAMUEBLES como un proyecto emprendedor enfocado en la fabricación y comercialización de muebles modernos estilo minimalista e inspirados en el diseño IKEA.</p>
                <p style="font-family:'Montserrat', sans-serif">La empresa surgió de jóvenes emprendedores apasionados por el diseño de interiores y la funcionalidad de los espacios modernos.</p>
                <p style="font-family:'Montserrat', sans-serif">Hoy <b style="color:#8B0909; font-weight:bold">KCAMUEBLES</b> ofrece escritorios, salas modulares, recámaras, comedores, libreros y soluciones de almacenamiento para transformar espacios con estilo y practicidad.</p>
            </div>
        </div>
    </div>
</div>



